        "# BasisEmbedding"
      ],
      "metadata": {
        "id": "7MuYjfIe5xql"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pennylane as qml\n",
        "import numpy as np\n",
        "\n",
        "dev = qml.device('reference.qubit', wires=3)\n",
        "\n",
        "@qml.qnode(dev)\n",
        "def circuit(feature_vector):\n",
        "    qml.BasisEmbedding(features=feature_vector, wires=range(3))\n",
        "    return qml.state()\n",
        "\n",
        "X = [1,0,1]\n",
        "print(qml.draw(circuit, level=\"device\")(X))\n",
        "print(circuit(X))"
      ],
