      "cell_type": "code",
      "source": [
        "dev = qml.device('default.qubit', wires=3)\n",
        "\n",
        "@qml.qnode(dev)\n",
        "def circuit(feature_vector):\n",
        "    qml.AngleEmbedding(features=feature_vector, wires=range(3), rotation='X')\n",
        "    #qml.Hadamard(0)\n",
