    {
      "cell_type": "code",
      "source": [
        "dev = qml.device('default.qubit', wires=2)\n",
        "\n",
        "@qml.qnode(dev)\n",
        "def circuit(f=None):\n",
        "    qml.AmplitudeEmbedding(features=f, wires=range(2), normalize=True)\n",
        "    return qml.state()\n",
        "\n",
        "state = circuit(f=[1/2, 1/2, 1/2, 1/2])\n",
        "print(state)"
